// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// 解体業者マスタ
// ─────────────────────────────────────────
model Company {
  id                 Int       @id @default(autoincrement())
  corporateNumber    String?   @unique @map("corporate_number") // 法人番号
  name               String
  furigana           String?
  prefectureName     String?   @map("prefecture_name")
  cityName           String?   @map("city_name")
  streetNumber       String?   @map("street_number")
  postCode           String?   @map("post_code")
  addressFull        String?   @map("address_full")
  phoneNumber        String?   @map("phone_number")
  websiteUrl         String?   @map("website_url")
  permitType         String?   @map("permit_type") // 特定建設業 / 一般建設業
  permitNumber       String?   @map("permit_number") // 許可番号（許可行政庁を含む。例: 東京都知事許可 第000005号）
  representativeName String?   @map("representative_name") // 代表者名
  officeAddress      String?   @map("office_address") // 主たる営業所の所在地（BizNav許可情報側。号室等の詳細を含む場合あり）
  capitalThousandYen Int?      @map("capital_thousand_yen") // 資本金額（単位: 千円）
  licensedTrades     Json?     @map("licensed_trades") // 保有する建設業許可一覧 [{ trade: string, level: string }]
  licenseValidFrom   DateTime? @map("license_valid_from") // 許可の有効期間（開始）
  licenseValidUntil  DateTime? @map("license_valid_until") // 許可の有効期間（終了）
  sources            String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  reviews Review[]

  @@index([prefectureName])
  @@index([name])
  @@map("companies")
}

// ─────────────────────────────────────────
// 口コミ投稿者
// ─────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  passwordHash String   @map("password_hash") // scrypt(salt:hash)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  reviews  Review[]
  sessions UserSession[]

  @@map("users")
}

// ─────────────────────────────────────────
// 会員ログインセッション
// ─────────────────────────────────────────
model UserSession {
  token     String   @id // ランダムな256bitトークン。cookieの値そのもの
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// ─────────────────────────────────────────
// 管理者アカウント
// ─────────────────────────────────────────
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash") // scrypt(salt:hash)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

enum AuthAttemptType {
  LOGIN
  REGISTER
}

// ─────────────────────────────────────────
// ログイン・会員登録の試行ログ（レート制限用）
// 期間で刈り取るバッチは未実装のため、蓄積量が問題になる場合は別途クリーンアップが必要
// ─────────────────────────────────────────
model AuthAttempt {
  id        Int             @id @default(autoincrement())
  type      AuthAttemptType
  ip        String? // X-Forwarded-For由来。信頼できるリバースプロキシが手前に無い構成では偽装され得る
  email     String?
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([type, ip, createdAt])
  @@index([type, email, createdAt])
  @@map("auth_attempts")
}

// ─────────────────────────────────────────
// 解体した建物の構造種別
// ─────────────────────────────────────────
enum StructureType {
  WOODEN // 木造住宅
  LIGHT_STEEL // 軽量鉄骨造
  STEEL // 鉄骨造
  RC // RC造（鉄筋コンクリート）
  OTHER // その他
}

// ─────────────────────────────────────────
// 口コミ
// ─────────────────────────────────────────
model Review {
  id            Int           @id @default(autoincrement())
  companyId     Int           @map("company_id")
  userId        Int?          @map("user_id") // nullable（既存の匿名シードデータ向け。新規投稿は必ずログイン必須）
  authorName    String?       @map("author_name") // 投稿者表示名（未入力=「匿名」）
  priceRating   Int           @map("price_rating") // 価格 1-5
  serviceRating Int           @map("service_rating") // 対応 1-5
  qualityRating Int           @map("quality_rating") // 仕上がり 1-5
  structureType StructureType @map("structure_type") // 解体した建物の構造
  workYear      Int?          @map("work_year") // 施工年
  isPublished   Boolean       @default(false) @map("is_published")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  editedAt      DateTime?     @map("edited_at") // ユーザーが編集した日時（承認操作では更新しない）

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([companyId, userId]) // 1ユーザー1業者につき口コミは1件まで（userIdがnullの行同士は対象外）
  @@index([companyId])
  @@index([userId]) // レート制限判定(userId単体での件数カウント)用。(companyId, userId)の複合indexは先頭列companyIdからしか使えない
  @@map("reviews")
}
